{
  "rewrites": [
    { "source": "/api/auth/register", "destination": "/api/auth-register.cjs" },
    { "source": "/api/auth/login", "destination": "/api/auth-login.cjs" },
    { "source": "/api/auth/me", "destination": "/api/auth-me.cjs" },
    { "source": "/api/notes/:id/favorite", "destination": "/api/notes-favorite.cjs?id=:id" },
    { "source": "/api/notes/:id/lock", "destination": "/api/notes-lock.cjs?id=:id" },
    { "source": "/api/notes/:id", "destination": "/api/notes-id.cjs?id=:id" },
    { "source": "/api/notes", "destination": "/api/notes.cjs" },
    { "source": "/api/folders/:id", "destination": "/api/folders-id.cjs?id=:id" },
    { "source": "/api/folders", "destination": "/api/folders.cjs" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}